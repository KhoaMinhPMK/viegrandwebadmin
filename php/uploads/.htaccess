<IfModule mod_php7.c>
  php_flag engine off
</IfModule>
<IfModule mod_php8.c>
  php_flag engine off
</IfModule>
Options -ExecCGI
AddType text/plain .php .php3 .php4 .php5 .phtml
<FilesMatch "\.(php|php3|php4|php5|phtml)$">
  ForceType text/plain
  Header set X-Content-Type-Options nosniff
</FilesMatch>

